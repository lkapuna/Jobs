MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/workhour
JWT_SECRET=your_super_secret_key_here
PORT=3000
ADMIN_EMAIL=alef.shin.jobs@gmail.com
ADMIN_PASSWORD=choose_a_strong_admin_password
ADMIN_PHONE=0500000000

# Optional: required for actual outgoing emails.
# Gmail requires an App Password, not the regular Gmail password.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alef.shin.jobs@gmail.com
SMTP_PASS=your_gmail_app_password_without_spaces
MAIL_FROM=א.ש השמת עובדים <alef.shin.jobs@gmail.com>

# If Render cannot connect to Gmail SMTP, switch to Gmail API over HTTPS:
# EMAIL_PROVIDER=gmail_api
# GMAIL_CLIENT_ID=your_google_oauth_client_id
# GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
# GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token

# Default behavior sends directly to the employer, so your admin email is not shown in the To field.
# Set HIDE_EMPLOYER_RECIPIENT=true only if you want to BCC the employer behind a different visible mailbox.
HIDE_EMPLOYER_RECIPIENT=false
MAIL_VISIBLE_TO=
MAIL_REPLY_TO=alef.shin.jobs@gmail.com
