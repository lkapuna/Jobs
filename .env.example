MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/workhour
JWT_SECRET=your_super_secret_key_here
PORT=3000
ADMIN_EMAIL=alef.shin.jobs@gmail.com
ADMIN_PASSWORD=choose_a_strong_admin_password
ADMIN_PHONE=0500000000

# Optional: required for actual outgoing emails.
# Recommended on Render: Resend API over HTTPS.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
MAIL_FROM=onboarding@resend.dev

# Default behavior sends directly to the employer, so your admin email is not shown in the To field.
# Set HIDE_EMPLOYER_RECIPIENT=true only if you want to BCC the employer behind a different visible mailbox.
HIDE_EMPLOYER_RECIPIENT=false
MAIL_VISIBLE_TO=
MAIL_REPLY_TO=alef.shin.jobs@gmail.com
